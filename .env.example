# Server
PORT=3000

# Your website's origin(s), comma-separated (e.g. https://deine-website.de)
ALLOWED_ORIGINS=https://deine-website.de

# A long, random secret — used to authenticate requests FROM your website TO this service
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Brevo
BREVO_API_KEY=
SENDER_EMAIL=noreply@deine-domain.de
SENDER_NAME=Dein Firmenname

# Redis
REDIS_URL=redis://localhost:6379

# A long random secret used to hash codes in Redis
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CODE_HASH_PEPPER=

# HMAC secret for signing QR codes (points & coupons)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QR_SECRET=

# JWT secret (same key as above or a separate one)
JWT_SECRET=

# Supabase (für serverseitigen Zugriff auf business_rewards)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=
